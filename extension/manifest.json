{
  "manifest_version": 3,
  "name": "AutoFlow – Video Task Manager for Google Flow",
  "version": "1.2.4",
  "description": "Automate prompt queues, upscale workflows, and bulk generation for Google Veo on Flow. Third-party tool, not affiliated with Google.",
  "minimum_chrome_version": "114",
  "offline_enabled": false,
  "homepage_url": "https://auto-flow.studio",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "downloads",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "https://labs.google/*",
    "https://api.auto-flow.studio/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://labs.google/flow*", "https://labs.google/fx*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "AutoFlow",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
