{
  "manifest_version": 3,
  "name": "AutoFlow – Video Task Manager for Google Flow",
  "version": "1.0.0",
  "description": "Queue, manage, and monitor video-generation tasks on Google Flow (labs.google/flow). Third-party tool, not affiliated with Google.",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "downloads",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "https://labs.google/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://labs.google/flow*", "https://labs.google/fx*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "AutoFlow",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
